{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🏥 Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "jinja": true,
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "python": "${workspaceFolder}/backend/.venv/bin/python"
    }, 
    {
      "name": "🖥️ Frontend",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}/frontend",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
