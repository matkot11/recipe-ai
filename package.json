    "@nuxt/test-utils": "^4.0.2",
    "@nuxtjs/eslint-module": "^4.1.0",
    "@nuxtjs/seo": "^5.1.3",
    "@resvg/resvg-js": "^2.6.2",
    "nuxt": "^4.4.2",
    "satori": "^0.26.0",
